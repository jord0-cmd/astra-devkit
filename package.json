{
  "name": "astra-devkit",
  "version": "4.0.4",
  "description": "AI Engineering Partner for Gemini CLI — 33 skills, 17 hooks, 9 agents, 10 MCPs, 2 modes (Code + Office)",
  "type": "module",
  "bin": {
    "astra-devkit": "./bin/run.js"
  },
  "files": [
    "bin/run.js",
    "src/",
    "lib/",
    "docs/images/",
    "personas/",
    "agents/",
    "commands/",
    "hooks/",
    "skills/",
    "standards/",
    "themes/",
    "GEMINI.md",
    "settings.json",
    "settings-template.json",
    "geminiignore.template",
    "LICENSE",
    "README.md"
  ],
  "oclif": {
    "bin": "astra-devkit",
    "dirname": "astra-devkit",
    "commands": "./src/commands",
    "topicSeparator": " ",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "dependencies": {
    "@ast-grep/cli": "^0.42.0",
    "@inquirer/prompts": "^8.0.0",
    "@oclif/core": "^4.0.0",
    "@oclif/plugin-help": "^6.0.0"
  },
  "keywords": [
    "gemini",
    "gemini-cli",
    "ai",
    "devkit",
    "skills",
    "hooks",
    "agents",
    "mcp",
    "engineering",
    "developer-tools"
  ],
  "author": "jord0-cmd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jord0-cmd/astra-devkit.git"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
